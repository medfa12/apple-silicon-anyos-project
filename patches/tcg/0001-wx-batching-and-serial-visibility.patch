diff --git a/tcg/aarch64/tcg-target.h b/tcg/aarch64/tcg-target.h
index eb474893..280b2a8e 100644
--- a/tcg/aarch64/tcg-target.h
+++ b/tcg/aarch64/tcg-target.h
@@ -152,22 +152,56 @@ typedef enum {
 #if defined(__APPLE__)
 #include <libkern/OSCacheControl.h>
 #include <pthread.h>
-/* Apple Silicon W^X protocol. tb_gen_code holds write-protect OFF for
- * the entire duration of TB construction (the TranslationBlock metadata
- * and the emitted machine code share a MAP_JIT region). flush_icache_range
- * just issues the cache flush — the X/W flip is handled by tb_gen_code. */
-static inline void tcg_apple_jit_writable_begin(void)
+/* Apple Silicon W^X protocol (an earlier iteration refcount rework).
+ *
+ * The TranslationBlock metadata AND the emitted machine code share a single
+ * MAP_JIT region, so even metadata writes need the calling thread in W mode.
+ * Previously every nested codegen helper issued its own
+ * pthread_jit_write_protect_np(0)/(1) pair -> an APRR kernel trap each, which
+ * dominated translation throughput (~120 TB/s).
+ *
+ * We replace the raw toggles with a thread-local NESTING REFCOUNT
+ * (qemu_jit_wx_depth). disable() only issues a real APRR trap on the 0->1
+ * transition; enable() only on the 1->0 transition. APRR state is per-thread,
+ * so a __thread counter is MTTCG-safe. The storage is defined once in
+ * tcg-target.inc.c.  Invariant: depth==0  <=>  thread is in X (execute) mode.
+ */
+extern __thread int qemu_jit_wx_depth;
+
+static inline void jit_write_protect_disable(void)
+{
+    if (__builtin_available(macOS 11.0, *)) {
+        if (qemu_jit_wx_depth++ == 0) {
+            pthread_jit_write_protect_np(0);   /* W on */
+        }
+    }
+}
+static inline void jit_write_protect_enable(void)
 {
     if (__builtin_available(macOS 11.0, *)) {
-        pthread_jit_write_protect_np(0);
+        if (--qemu_jit_wx_depth == 0) {
+            pthread_jit_write_protect_np(1);   /* X on */
+        }
     }
 }
+/* Balanced writable window helpers (route through the refcount). */
+static inline void tcg_apple_jit_writable_begin(void)
+{
+    jit_write_protect_disable();
+}
+static inline void tcg_apple_jit_writable_end(void)
+{
+    jit_write_protect_enable();
+}
 static inline void flush_icache_range(uintptr_t start, uintptr_t stop)
 {
     sys_icache_invalidate((void *)start, stop - start);
 }
 #else
+static inline void jit_write_protect_disable(void) {}
+static inline void jit_write_protect_enable(void) {}
 static inline void tcg_apple_jit_writable_begin(void) {}
+static inline void tcg_apple_jit_writable_end(void) {}
 static inline void flush_icache_range(uintptr_t start, uintptr_t stop)
 {
     __builtin___clear_cache((char *)start, (char *)stop);
diff --git a/tcg/aarch64/tcg-target.inc.c b/tcg/aarch64/tcg-target.inc.c
index 799a891d..2b195e4e 100644
--- a/tcg/aarch64/tcg-target.inc.c
+++ b/tcg/aarch64/tcg-target.inc.c
@@ -13,6 +13,13 @@
 #include "../tcg-pool.inc.c"
 #include "qemu/bitops.h"
 
+#if defined(__APPLE__) && defined(__aarch64__)
+/* single definition of the thread-local W^X nesting refcount.
+ * Declared `extern __thread int qemu_jit_wx_depth;` in tcg-target.h and used
+ * by jit_write_protect_disable()/enable(). depth==0 <=> thread in X mode. */
+__thread int qemu_jit_wx_depth = 0;
+#endif
+
 /* We're going to re-use TCGType in setting of the SF bit, which controls
    the size of the operation performed.  If we know the values match, it
    makes things much cleaner.  */
@@ -1368,6 +1375,11 @@ void tb_target_set_jmp_target(uintptr_t tc_ptr, uintptr_t jmp_addr,
     tcg_apple_jit_writable_begin();
     atomic_set((uint64_t *)jmp_addr, pair);
     flush_icache_range(jmp_addr, jmp_addr + 8);
+    /* balance the writable window. When called from inside
+     * tb_gen_code the refcount stays >0 (no extra trap); when called from the
+     * runtime tb_add_jump chaining path this restores X mode before JIT code
+     * executes again, fixing a latent SIGBUS where the thread was left in W. */
+    tcg_apple_jit_writable_end();
 }
 
