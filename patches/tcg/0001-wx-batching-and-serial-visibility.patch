+#if defined(__APPLE__) && defined(__aarch64__)
+        /* cpu_loop_exit() does siglongjmp out of this function.
+         * If we reached here via a buffer_overflow retry the writable window
+         * may already be open; close it first so the thread is left in X mode
+         * and the refcount does not leak (a stranded W window SIGBUSes on the
+         * next JIT execution). */
+        if (wx_open) {
