diff --git a/hw/arm/j273_macos11.c b/hw/arm/j273_macos11.c
index f44ef719..970a643a 100644
--- a/hw/arm/j273_macos11.c
+++ b/hw/arm/j273_macos11.c
@@ -327,16 +327,14 @@ struct darwin_kernel_patch darwin_patches_20C69 = {
         DARWIN_PATCH(0xfffffe000806b438, g_w10_zero_inst), // parse_machfile slide set instruction
         DARWIN_PATCH(0xfffffe0008cb6538, g_mov_w0_01_inst), // core trust check
         DARWIN_PATCH(0xfffffe000806b234, g_nop_inst), // load_machfile: disable IMGPF_NOJOP
-        // an earlier experiment: tried forcing kprintf's u32 flags
-        // at PA-equivalent of VA 0xfffffe000a430c8c / 0xa430cd8 to
-        // all-ones to skip the cbz at 0x8265d14 and reach serial_putc
-        // directly. Did NOT produce serial output by itself --
-        // serial_putc internally CBZs on a function pointer
-        // (PE_serial_putc) loaded from 0xa430950 which is still NULL
-        // until PE_init_kprintf runs. Patches retained in case
-        // they help once the function pointer is wired up.
-        DARWIN_PATCH(0xfffffe000a430c8c, g_kprintf_enable), // kprintf enable flag A
-        DARWIN_PATCH(0xfffffe000a430cd8, g_kprintf_enable), // kprintf enable flag B
+        // repointed kprintf enable flags to the CORRECT words.
+        // Disassembly of _kprintf @0xfffffe0008265cd0 shows it loads two
+        // u32s via `adrp x8,0xa430000; ldr w8,[x8,#0x8c8]` and
+        // `ldr w9,[x9,#0x8d8]`, ORs them, then `cbz w8`. So the gate words
+        // are at VA 0xa4308c8 and 0xa4308d8 -- NOT the previous (incorrect) addresses
+        // 0xa430c8c/0xa430cd8 (which hit unrelated words and had no effect).
+        DARWIN_PATCH(0xfffffe000a4308c8, g_kprintf_enable), // kprintf enable flag A
+        DARWIN_PATCH(0xfffffe000a4308d8, g_kprintf_enable), // kprintf enable flag B
     }
 };
 
