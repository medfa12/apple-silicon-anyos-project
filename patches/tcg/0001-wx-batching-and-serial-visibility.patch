+    if (!wx_open) {
+        jit_write_protect_disable();
+        wx_open = true;
     }
 #endif
 
@@ -1935,18 +1959,24 @@ TranslationBlock *tb_gen_code(CPUState *cpu,
         atomic_set(&tcg_ctx->code_gen_ptr, (void *)orig_aligned);
         tb_destroy(tb);
 #if defined(__APPLE__) && defined(__aarch64__)
-        if (__builtin_available(macOS 11.0, *)) {
-            pthread_jit_write_protect_np(1);
-            sys_icache_invalidate(gen_code_buf, gen_code_size > 0 ? gen_code_size : 1);
+        /* invalidate the emitted range (we did write code), then
+         * close the single writable window via the refcount (restores X). */
+        sys_icache_invalidate(gen_code_buf, gen_code_size > 0 ? gen_code_size : 1);
+        if (wx_open) {
+            jit_write_protect_enable();
+            wx_open = false;
         }
 #endif
         return existing_tb;
     }
     tcg_tb_insert(tb);
 #if defined(__APPLE__) && defined(__aarch64__)
-    if (__builtin_available(macOS 11.0, *)) {
-        pthread_jit_write_protect_np(1);
-        sys_icache_invalidate(gen_code_buf, gen_code_size > 0 ? gen_code_size : 1);
+    /* invalidate the emitted range, then close the single
+     * writable window via the refcount (restores X mode for execution). */
+    sys_icache_invalidate(gen_code_buf, gen_code_size > 0 ? gen_code_size : 1);
+    if (wx_open) {
+        jit_write_protect_enable();
