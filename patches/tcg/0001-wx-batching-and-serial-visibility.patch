-    if (__builtin_available(macOS 11.0, *)) {
-        pthread_jit_write_protect_np(0);
+     * to writable mode for the whole duration of this function.
+     *
+     * route through the refcounted API and open the window
+     * exactly once. The buffer_overflow retry re-enters here after
+     * tcg_tb_alloc; wx_open prevents a redundant disable()/extra APRR trap
+     * and prevents a refcount leak. Note the alloc-failure path above
+     * (tcg_tb_alloc==NULL -> cpu_loop_exit) runs BEFORE this, so wx_open is
